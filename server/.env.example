PORT=3001
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dasha-moscow
JWT_SECRET=change-me-long-random-string
ADMIN_PASSWORD=your-admin-password
DASHA_PASSWORD=your-dasha-password
# Vercel URL (можно несколько через запятую: prod,preview)
CLIENT_URL=https://your-app.vercel.app
# Публичный URL этого сервера (для ссылок на загрузки)
API_PUBLIC_URL=https://dasha-moscow-api.onrender.com
START_DATE=2026-05-25
UNLOCK_ALL_DAYS=false
# NODE_ENV=production на Render задаётся автоматически
# SERVE_CLIENT=true — только если отдаёшь client/dist с этого же процесса
